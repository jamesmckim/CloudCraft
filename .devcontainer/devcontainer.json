{
    "name": "CloudCraft Enterprise Dev",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "version": "latest",
            "enableNonRootDocker": "true",
            "moby": "true"
        }
    },
    "mounts": [
        "source=${localEnv:USERPROFILE}/AppData/Roaming/sops/age/keys.txt,target=/home/vscode/.config/sops/age/keys.txt,type=bind,readonly",
        "source=${localEnv:USERPROFILE}/.kube,target=/tmp/.kube-localhost,type=bind,readonly"
    ],
    "remoteEnv": {
        "SOPS_AGE_KEY_FILE": "/home/vscode/.config/sops/age/keys.txt",
        "KUBECONFIG": "/home/vscode/.kube/config"
    },
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "remoteUser": "vscode"
}